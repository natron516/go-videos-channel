rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TV sessions — anyone can create, only owner can write uid, admin writes customToken
    match /tvSessions/{sessionCode} {
      allow create: if true;
      allow read: if true;
      allow update: if request.auth != null && request.auth.uid == resource.data.get('uid', null)
                    || request.auth == null; // web page pre-auth update
    }

    // User playlists — each user owns their own data
    match /users/{userId}/playlists/{playlistId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // App config (PIN, featured list) — public read, server writes via Admin SDK
    match /config/{doc} {
      allow read: if true;
      allow write: if false; // Admin SDK bypasses rules
    }

    // Thumbnails — stored by admin server (no auth required for this collection)
    match /thumbnails/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // App feedback — anyone can submit, admin reads via Admin SDK
    match /feedback/{doc} {
      allow create: if true;
      allow read, update, delete: if false; // Admin SDK bypasses rules
    }

    // Session tracking — app writes, admin reads via Admin SDK
    match /sessions/{doc} {
      allow create, update: if request.auth != null;
      allow read, delete: if false; // Admin SDK bypasses rules
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
