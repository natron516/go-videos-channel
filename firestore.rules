rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TV sessions — anyone can create, only owner can write uid, admin writes customToken
    match /tvSessions/{sessionCode} {
      allow create: if true;
      allow read: if true;
      allow update: if request.auth != null && request.auth.uid == resource.data.get('uid', null)
                    || request.auth == null; // web page pre-auth update
    }

    // User playlists — each user owns their own data
    match /users/{userId}/playlists/{playlistId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
